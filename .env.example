# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
#
# For local Docker install: run install.sh — it fills this in for you.
# For Railway/cloud deploy: run ./railway-env-sync.sh
# ─────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────
# Docker install: DB_HOST must be "db" (the compose service name)
# Railway: leave blank — DATABASE_URL is set automatically
DB_HOST=db
DB_PORT=5432
DB_USER=tradebuddy
DB_PASSWORD=             # auto-generated by install.sh
DB_NAME=tradebuddy

# ── App ─────────────────────────────────────────────────────────
API_PORT=3001
APP_URL=http://localhost:3001   # change to your domain in production
NODE_ENV=production

# ── Secrets (generate with: openssl rand -hex 32) ───────────────
JWT_SECRET=
SNAPSHOT_SECRET=
LLM_ENCRYPTION_KEY=

# ── Market data ─────────────────────────────────────────────────
# Get a free key at https://polygon.io
POLYGON_API_KEY=

# ── Email / password reset (optional) ───────────────────────────
# Get a free key at https://resend.com
# Leave blank to disable password reset emails
RESEND_API_KEY=
EMAIL_FROM=TradeBuddy <onboarding@resend.dev>

# ── First-run admin setup (auto-removed after first boot) ────────
# Set these to create the initial admin account automatically.
# install.sh fills these in and removes them once the app has started.
SETUP_ADMIN_NAME=
SETUP_ADMIN_EMAIL=
SETUP_ADMIN_PASSWORD=

# ── Google Sign-In (optional) ────────────────────────────────────
# Leave blank for local installs — email/password works without it
# Get credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=   # same value as above — baked into frontend at build time
GOOGLE_CLIENT_SECRET=
