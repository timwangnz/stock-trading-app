ANTHROPIC_API_KEY=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

# ── JWT secret ─────────────────────────────────────────────────
# Any long random string — used to sign session tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=7e444703ef4fa33c01890f3b1a0cc2dd6e60e30857f661867185a712b4101766

# ── Portfolio snapshot secret ───────────────────────────────────
# Shared secret for the internal /api/internal/snapshot-all endpoint.
# The daily scheduled task must send this in the x-snapshot-secret header.
SNAPSHOT_SECRET=4cc68f852b6a6f67464adc28e927dd19f0291075ef07e397ba2381a0ccc0a5e4
SNAPSHOT_ALERT_EMAIL=anpwang@gmail.com

# ── LLM API key encryption ──────────────────────────────────────
# 32-byte (64 hex chars) key used to AES-256-GCM encrypt user API keys at rest.
# Generate a new one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this key will invalidate all saved user API keys.
LLM_ENCRYPTION_KEY=1738ea4f4d959d2da67a5550da8925edd85406051fd3411381a993851597a1d9

