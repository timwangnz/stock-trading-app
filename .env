# ── Polygon.io API Key ─────────────────────────────────────────
# Server-side only — no VITE_ prefix, so it is NEVER bundled into
# the browser JS. The frontend calls /api/market/* and the server
# forwards the request to Polygon with the key attached.

POLYGON_API_KEY=wVTlx62PEVcQUrRDxJuYGOpUqlsnQ_MN

# ── PostgreSQL (backend only — no VITE_ prefix keeps it out of the browser bundle) ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=luckie
DB_PASSWORD=luckie123
DB_NAME=stockvibe

# To reset the database, run:
# psql -U luckie -d stockvibe -c "DROP OWNED BY luckie; CREATE SCHEMA public;"
SETUP_ADMIN_EMAIL=admin@gmail.com
SETUP_ADMIN_PASSWORD=welcome123
SETUP_ADMIN_NAME=Admin


# Express server port
API_PORT=3001

# ── Google OAuth ───────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorised JavaScript origins: http://localhost:5173
# 5. Authorised redirect URIs: http://localhost:5173
# 6. Copy the Client ID into both variables below
# ... 630880894101-v6926m8de0aoqvsjel9f17nvikbla7kt.apps.googleusercontent.com

GOOGLE_CLIENT_ID=630880894101-v6926m8de0aoqvsjel9f17nvikbla7kt.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=630880894101-v6926m8de0aoqvsjel9f17nvikbla7kt.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Production app URL (used for Google OAuth callback and password reset links)
APP_URL=http://localhost:5173

# ── Resend (password reset emails) ─────────────────────────────
# Get your API key at https://resend.com → API Keys
# Verify a domain at https://resend.com → Domains, then set EMAIL_FROM
RESEND_API_KEY=re_8JsSWxkM_4EZHjg71ZHtLLWLYHLtKCv3U
EMAIL_FROM==TradeBuddy <onboarding@resend.dev> 
# ── Anthropic API (Trading Agent) ──────────────────────────────
