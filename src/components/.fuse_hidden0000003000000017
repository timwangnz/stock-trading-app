/**
 * StockCard.jsx
 * A reusable card showing a stock's symbol, name, price, and daily change.
 * Clicking the card navigates to that stock's detail page.
 */

import { TrendingUp, TrendingDown } from 'lucide-react'
import { useApp, ACTIONS } from '../context/AppContext'
import clsx from 'clsx'

export default function StockCard({ stockInfo }) {
  const { dispatch } = useApp()
  const { symbol, name, price, change, changePct } = stockInfo

  const isPositive = change >= 0

  return (
    <button
      onClick={() => dispatch({ type: ACTIONS.VIEW_STOCK, payload: symbol })}
      className="bg-surface-card hover:bg-surface-hover border border-slate-200 hover:border-slate-200 rounded-xl p-4 text-left transition-all group w-full"
    >
      {/* Top row: symbol + trend icon */}
      <div className="flex items-center justify-between mb-3">
        <span className="text-white font-mono font-bold text-base">{symbol}</span>
        {isPositive
          ? <TrendingUp size={16} className="text-gain" />
          : <TrendingDown size={16} className="text-loss" />
        }
      </div>

      {/* Company name */}
      <p className="text-slate-400 text-xs mb-3 truncate">{name}</p>

      {/* Price */}
      <p className="text-white font-semibold text-xl mb-1">
        ${price.toFixed(2)}
      </p>

      {/* Daily change */}
      <p className={clsx('text-sm font-medium', isPositive ? 'text-gain' : 'text-loss')}>
        {isPositive ? '+' : ''}{change.toFixed(2)} ({isPositive ? '+' : ''}{changePct.toFixed(2)}%)
      </p>
    </button>
  )
}
